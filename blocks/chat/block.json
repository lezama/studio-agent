{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "studio-agent/chat",
	"version": "0.2.0",
	"title": "Studio Agent Chat",
	"category": "widgets",
	"description": "Chat with the Studio Agent. Inspect the site, generate themes, and preview them in a Playground iframe.",
	"textdomain": "studio-agent",
	"supports": {
		"html": false,
		"reusable": false,
		"inserter": false
	},
	"attributes": {
		"defaultAgent": {
			"type": "string",
			"default": "studio"
		},
		"showPreview": {
			"type": "boolean",
			"default": true
		},
		"showSlashMenu": {
			"type": "boolean",
			"default": true
		},
		"variant": {
			"type": "string",
			"default": "full",
			"enum": ["full", "chat-only", "preview-only"]
		}
	},
	"render": "file:./render.php",
	"viewScript": "file:./build/view.js",
	"viewStyle": "file:./build/view.css"
}
